{
  "name": "voice-ai-backend",
  "version": "0.1.0",
  "description": "Voice AI platform - WebSocket voice streaming server and STT/LLM/TTS pipeline",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc && cp -r src/generated dist",
    "dev": "tsx watch src/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "worker:postcall": "tsx src/workers/postcall-worker.ts",
    "worker:voice": "tsx src/workers/voice-worker.ts",
    "worker:embedding": "tsx src/workers/embedding-worker.ts",
    "worker:tools": "tsx src/workers/tool-worker.ts",
    "worker:webhooks": "tsx src/workers/webhook-worker.ts",
    "worker:billing": "tsx src/billing/billing-worker.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@deepgram/sdk": "^3.13.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@google/generative-ai": "^0.24.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "ari-client": "^2.2.0",
    "assemblyai": "^4.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.2",
    "dotenv": "^16.4.5",
    "elevenlabs": "^0.15.0",
    "fastify": "^5.1.0",
    "ffmpeg-static": "^5.3.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.0",
    "openai": "^4.73.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playht": "^0.21.0",
    "prisma": "^7.4.2",
    "prom-client": "^15.1.3",
    "stripe": "^20.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
