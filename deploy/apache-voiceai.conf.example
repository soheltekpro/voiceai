# Apache config for Voice AI (Node backend on 3000).
# Copy to /etc/apache2/sites-available/voiceai.conf and enable with a2ensite.
# Replace voiceai.tittu.in with your domain (or use ServerName _ for default).

# Required modules: sudo a2enmod proxy proxy_http proxy_wstunnel rewrite

<VirtualHost *:80>
    ServerName voiceai.tittu.in
    DocumentRoot /var/www/voiceai/frontend/dist

    <Directory /var/www/voiceai/frontend/dist>
        Options -Indexes +FollowSymLinks
        AllowOverride None
        Require all granted
        FallbackResource /index.html
    </Directory>

    # API (Node backend)
    ProxyPreserveHost On
    ProxyPass /api http://127.0.0.1:3000/api
    ProxyPassReverse /api http://127.0.0.1:3000/api

    # WebSocket /voice
    RewriteEngine On
    RewriteCond %{HTTP:Upgrade} websocket [NC]
    RewriteCond %{HTTP:Connection} upgrade [NC]
    RewriteRule ^/voice$ ws://127.0.0.1:3000/voice [P,L]
    ProxyPass /voice http://127.0.0.1:3000/voice
    ProxyPassReverse /voice http://127.0.0.1:3000/voice

    ErrorLog ${APACHE_LOG_DIR}/voiceai-error.log
    CustomLog ${APACHE_LOG_DIR}/voiceai-access.log combined
</VirtualHost>

# HTTPS (after certbot: sudo certbot --apache -d voiceai.tittu.in)
