# Optional: Backend API base URL. If set, the app calls the backend directly (bypasses Vite proxy).
# Use this if the proxy gets ECONNREFUSED (e.g. when running frontend and backend in different contexts).
# VITE_API_URL=http://127.0.0.1:3000

# Optional: WebSocket URL for the voice pipeline. Use this if you see "ws proxy socket error: ECONNRESET".
# Connects directly to the backend instead of going through the Vite proxy.
# VITE_WS_VOICE_URL=ws://127.0.0.1:3000/voice
