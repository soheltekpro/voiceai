// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum VoiceProvider {
  OPENAI
  ELEVENLABS
}

enum InterruptionBehavior {
  BARGE_IN_STOP_AGENT
  IGNORE_WHILE_SPEAKING
}

enum CallClientType {
  BROWSER
  PHONE
  UNKNOWN
}

enum CallSessionStatus {
  ACTIVE
  ENDED
  ERROR
}

enum CallEventType {
  SESSION_STARTED
  SESSION_CONNECTED
  SESSION_ENDED
  TRANSCRIPT_PARTIAL
  TRANSCRIPT_FINAL
  AGENT_TEXT_DELTA
  AGENT_REPLY
  AGENT_AUDIO_START
  AGENT_AUDIO_CHUNK
  AGENT_AUDIO_END
  AGENT_SPEAKING
  AGENT_FINISHED
  INTERRUPT
  AGENT_STOPPED
  ERROR
  USAGE_UPDATED
  TOOL_CALLED
  TOOL_RESULT
  RECORDING_AVAILABLE
  HANDOFF_REQUESTED
}

enum CallMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AgentType {
  PIPELINE
  V2V
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users           User[]
  apiKeys         ApiKey[]
  agents          Agent[]
  knowledgeBases  KnowledgeBase[]
  tools           Tool[]
  sipTrunks       SipTrunk[]
  phoneNumbers    PhoneNumber[]
  calls           Call[]
  documents       Document[]
  workspacePlans  WorkspacePlan[]
  workspaceUsages WorkspaceUsage[]
  webhooks        Webhook[]
  voiceUsages       VoiceUsage[]
  workspaceVoicePlan WorkspaceVoicePlan?
  workspaceBilling  WorkspaceBilling?
  billingEvents     BillingEvent[]
  voiceConversationMemories VoiceConversationMemory[]
  voiceCallOutcomes        VoiceCallOutcome[]
  voiceCallGuidances       VoiceCallGuidance[]
  voiceCallEvaluations     VoiceCallEvaluation[]
  voicePromptOptimizations VoicePromptOptimization[]
  voicePromptVersions      VoicePromptVersion[]

  @@map("workspaces")
}

model WorkspaceVoicePlan {
  workspaceId           String   @unique
  planName              String
  monthlyCallMinutes    Int      @default(0)   // 0 = unlimited
  monthlyLLMTokens      Int      @default(0)   // 0 = unlimited
  monthlyTTSCharacters  Int      @default(0)   // 0 = unlimited
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_voice_plan")
}

enum BillingSubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

model WorkspaceBilling {
  id                    String                    @id @default(uuid())
  workspaceId            String                    @unique
  stripeCustomerId      String?
  stripeSubscriptionId   String?
  planName              String
  status                BillingSubscriptionStatus @default(ACTIVE)
  subscriptionItemIds   Json?                     // { callMinutes?: string, llmTokens?: string, ttsCharacters?: string } for metered usage
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@map("workspace_billing")
}

model BillingEvent {
  id             String   @id @default(uuid())
  stripeEventId  String   @unique
  workspaceId    String?
  eventType      String
  payload        Json
  createdAt      DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([eventType])
  @@index([createdAt])
  @@map("billing_events")
}

model VoiceConversationMemory {
  id          String    @id @default(uuid())
  workspaceId String
  phoneNumber String
  summary     String
  lastCallId  String?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, phoneNumber])
  @@index([workspaceId, phoneNumber])
  @@map("voice_conversation_memory")
}

model VoiceCallOutcome {
  id               String   @id @default(uuid())
  callId           String   @unique
  workspaceId      String
  promptVersionId  String?  // A/B: which prompt version handled the call
  outcome          String
  confidence       Float
  summary          String
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([outcome])
  @@index([promptVersionId])
  @@map("voice_call_outcome")
}

model VoiceCallGuidance {
  id           String   @id @default(uuid())
  callId       String
  workspaceId  String
  suggestion   String
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([callId])
  @@map("voice_call_guidance")
}

model VoiceCallEvaluation {
  id           String   @id @default(uuid())
  callId       String   @unique
  workspaceId  String
  score        Float
  strengths    String
  improvements String
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("voice_call_evaluation")
}

model VoicePromptOptimization {
  id          String   @id @default(uuid())
  workspaceId String
  agentId     String
  suggestion  String   @db.Text
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([agentId])
  @@map("voice_prompt_optimization")
}

model VoicePromptVersion {
  id           String   @id @default(uuid())
  workspaceId  String
  agentId      String
  version      Int
  systemPrompt String   @db.Text
  isActive     Boolean  @default(false)
  trafficShare Int      @default(100)
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([agentId])
  @@map("voice_prompt_version")
}

enum PricingType {
  PER_MINUTE
  PER_TOKEN
  PER_CHARACTER
}

model ProviderPricing {
  id           String      @id @default(uuid())
  providerName String
  pricingType  PricingType
  pricePerUnit Decimal     @db.Decimal(12, 6)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([providerName, pricingType])
  @@index([providerName])
  @@map("provider_pricing")
}

model VoiceUsage {
  id                  String    @id @default(uuid())
  callId              String
  workspaceId         String
  agentId             String
  startedAt           DateTime
  endedAt             DateTime?
  audioInputSeconds   Float     @default(0)
  audioOutputSeconds  Float     @default(0)
  llmInputTokens      Int       @default(0)
  llmOutputTokens     Int       @default(0)
  ttsCharacters       Int       @default(0)
  sttProvider         String?
  llmProvider         String?
  ttsProvider         String?
  sttCost             Float     @default(0)
  llmCost             Float     @default(0)
  ttsCost             Float     @default(0)
  totalCost           Float     @default(0)
  createdAt           DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, endedAt])
  @@map("voice_usage")
}

model Webhook {
  id          String   @id @default(uuid())
  workspaceId String
  url         String
  events      String[]
  secret      String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("webhooks")
}

model Plan {
  id               String   @id @default(uuid())
  name             String
  price            Decimal  @db.Decimal(10, 4)
  callMinutesLimit Int?     // null = unlimited
  tokenLimit       Int?     // null = unlimited
  toolCallsLimit   Int?     // null = unlimited
  sttSecondsLimit  Int?     // optional
  ttsSecondsLimit  Int?     // optional
  createdAt        DateTime @default(now())

  workspacePlans WorkspacePlan[]

  @@map("plans")
}

enum WorkspacePlanStatus {
  ACTIVE
  CANCELLED
}

model WorkspacePlan {
  workspaceId String
  planId      String
  status      WorkspacePlanStatus @default(ACTIVE)
  createdAt   DateTime            @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([workspaceId])
  @@index([planId])
  @@map("workspace_plans")
}

model WorkspaceUsage {
  id          String   @id @default(uuid())
  workspaceId String
  metric      String   // call_minutes, llm_tokens, stt_seconds, tts_seconds, tool_calls
  value       Int      @default(0) // cumulative for the period
  periodStart DateTime
  periodEnd   DateTime
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, metric, periodStart])
  @@index([workspaceId])
  @@index([workspaceId, periodStart])
  @@map("workspace_usage")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  workspaceId  String
  role         UserRole  @default(MEMBER)
  createdAt    DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("users")
}

model ApiKey {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  key         String   // hashed or prefix+secret
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([key])
  @@map("api_keys")
}

model Agent {
  id          String        @id @default(uuid())
  workspaceId String
  name        String
  description String?
  agentType   AgentType     @default(PIPELINE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  settings    AgentSettings?
  callSessions CallSession[]
  agentTools  AgentTool[]
  phoneNumbers PhoneNumber[]

  @@index([workspaceId])
  @@index([agentType])
  @@map("agents")
}

enum ToolType {
  WEBHOOK
  HTTP_REQUEST
  DATABASE_LOOKUP
  HUMAN_HANDOFF
}

model Tool {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  description String?
  type        ToolType
  config      Json     // type-specific config (url, method, etc.)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agents    AgentTool[]

  @@index([workspaceId])
  @@map("tools")
}

model AgentTool {
  agentId String
  toolId  String

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tool  Tool  @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@id([agentId, toolId])
  @@map("agent_tools")
}

enum CallStatus {
  ACTIVE
  ENDED
  ERROR
}

enum ConversationMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

model Call {
  id                String      @id @default(uuid())
  workspaceId       String
  agentId           String
  agentType         AgentType
  status            CallStatus  @default(ACTIVE)
  startedAt         DateTime    @default(now())
  endedAt           DateTime?
  durationSeconds   Int?
  transcript        String?
  recordingEnabled  Boolean     @default(true)
  recordingUrl      String?
  recordingDuration Int?        // seconds
  tokensUsed        Int?
  callSessionId     String?     // link to call_sessions for pipeline/v2v
  promptVersionId   String?    // A/B: which prompt version handled this call

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversationMessages ConversationMessage[]

  @@index([workspaceId])
  @@index([agentId])
  @@index([startedAt])
  @@index([status])
  @@index([callSessionId])
  @@index([promptVersionId])
  @@map("calls")
}

model ConversationMessage {
  id        String                 @id @default(uuid())
  callId    String
  role      ConversationMessageRole
  content   String                 @db.Text
  createdAt DateTime               @default(now())

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId, createdAt])
  @@map("conversation_messages")
}

model AgentSettings {
  id                     String                @id @default(uuid())
  agentId                String                @unique
  systemPrompt           String                @default("You are a helpful voice assistant.")
  language               String                @default("en")
  voiceProvider          VoiceProvider         @default(OPENAI)
  voiceName              String                @default("alloy")
  sttProvider            String?               // openai | deepgram | assemblyai
  sttModel               String?               // e.g. whisper-1, nova-2
  llmProvider            String?               // openai | google | anthropic
  llmModel               String?               // e.g. gpt-4o, gemini-1.5-flash, claude-3-haiku
  ttsProvider            String?               // openai | elevenlabs | playht
  ttsVoice               String?               // voice id per provider
  temperature            Float?                @default(0.7) // 0–2 for LLM
  maxCallDurationSeconds Int                   @default(900)
  interruptionBehavior   InterruptionBehavior  @default(BARGE_IN_STOP_AGENT)
  knowledgeBaseId        String?
  v2vProvider            String?               // openai | google — only for V2V agents
  v2vModel               String?               // e.g. gpt-4o-realtime-preview, gemini-2.5-flash-native-audio-*
  v2vVoice               String?               // e.g. alloy, Puck
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  agent         Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase? @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)

  @@map("agent_settings")
}

model KnowledgeBase {
  id          String     @id @default(uuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents   Document[]
  agentSettings AgentSettings[]

  @@index([workspaceId])
  @@map("knowledge_bases")
}

model Document {
  id              String        @id @default(uuid())
  workspaceId     String
  knowledgeBaseId String
  name            String        // display name or filename
  sourceType      String        // "pdf" | "text" | "url"
  sourceRef       String?       // URL or file path if applicable
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase  @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks        DocumentChunk[]

  @@index([workspaceId])
  @@index([knowledgeBaseId])
  @@map("documents")
}

model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String
  content    String   @db.Text
  index      Int      // order within document
  embedding  Unsupported("vector(1536)")? // OpenAI text-embedding-3-small

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

model CallSession {
  id               String            @id @default(uuid())
  agentId          String?
  promptVersionId  String?           // A/B: which prompt version used for this session
  clientType       CallClientType    @default(UNKNOWN)
  status      CallSessionStatus @default(ACTIVE)
  startedAt   DateTime          @default(now())
  endedAt     DateTime?
  metadata    Json?

  // Phase 6 + Phase 10: analytics and usage (pipeline + v2v)
  durationSeconds      Int?
  userMessageCount     Int          @default(0)
  assistantMessageCount Int         @default(0)
  transcriptText       String?      // concatenated user transcript for search
  estimatedCostUsd     Decimal?     @db.Decimal(10, 4)
  inputTokens          Int?         // e.g. audio/text input tokens (v2v/pipeline)
  outputTokens         Int?         // e.g. audio/text output tokens

  agent  Agent?      @relation(fields: [agentId], references: [id], onDelete: SetNull)
  events CallEvent[]
  messages CallMessage[]

  @@index([agentId])
  @@index([promptVersionId])
  @@index([startedAt])
  @@index([status, startedAt])
  @@map("call_sessions")
}

model CallEvent {
  id         String        @id @default(uuid())
  sessionId  String
  type       CallEventType
  timestamp  DateTime      @default(now())
  payload    Json?

  session CallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@map("call_events")
}

model CallMessage {
  id        String          @id @default(uuid())
  sessionId String
  role      CallMessageRole
  text      String
  createdAt DateTime        @default(now())

  // Optional analytics/cost info
  tokensEstimated Int?
  costUsd        Decimal?    @db.Decimal(10, 4)

  session CallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("call_messages")
}

model SipTrunk {
  id          String   @id @default(uuid())
  workspaceId String
  provider    String   // e.g. TWILIO, PLIVO, TELNYX
  name        String
  config      Json     // provider-specific (credentials, endpoint, etc.)
  createdAt   DateTime @default(now())

  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  phoneNumbers  PhoneNumber[]

  @@index([workspaceId])
  @@index([provider])
  @@map("sip_trunks")
}

model PhoneNumber {
  id          String   @id @default(uuid())
  workspaceId String
  number      String   // E.164 or provider format
  provider    String   // same as trunk typically
  sipTrunkId  String
  agentId     String?  // assigned agent for inbound; null = unassigned
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sipTrunk  SipTrunk  @relation(fields: [sipTrunkId], references: [id], onDelete: Cascade)
  agent     Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@unique([number, sipTrunkId])
  @@index([workspaceId])
  @@index([sipTrunkId])
  @@index([agentId])
  @@index([number])
  @@map("phone_numbers")
}
