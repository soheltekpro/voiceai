# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Postgres (Phase 3)
# Example: postgres://postgres:postgres@localhost:5432/voiceai?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voiceai?schema=public

# OpenAI (required for Phase 1: STT, LLM, TTS)
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: override defaults
# STT_MODEL=whisper-1
# LLM_MODEL=gpt-4o-mini
# TTS_MODEL=tts-1
# TTS_VOICE=alloy

# Pipeline tuning (milliseconds)
# Min audio (ms) before running STT in batch mode; use 1500–2500 to capture full phrases
# MIN_AUDIO_MS=1800
# MAX_BUFFER_MS=4000

# Phase 2: Streaming STT (optional; if set, real-time pipeline is used)
# DEEPGRAM_API_KEY=your_deepgram_api_key
# DEEPGRAM_MODEL=nova-2
# DEEPGRAM_LANGUAGE=en

# Phase 4: Asterisk ARI (optional; enables SIP/RTP telephony)
# ASTERISK_ARI_URL=http://127.0.0.1:8088
# ASTERISK_ARI_USERNAME=asterisk
# ASTERISK_ARI_PASSWORD=asterisk
# ASTERISK_ARI_APP=voiceai
#
# Host that Asterisk can reach to send RTP to this Node service:
# ASTERISK_RTP_HOST=YOUR_NODE_PUBLIC_IP_OR_DOCKER_HOST
#
# Node RTP bind + port pool used per call:
# TELEPHONY_RTP_BIND=0.0.0.0
# TELEPHONY_RTP_PORT_START=40000
# TELEPHONY_RTP_PORT_END=40100

# Phase 7: Redis (required for scaling features: rate limiting, queues, session index)
REDIS_URL=redis://127.0.0.1:6379

# V2V / LiveKit (optional; required only for V2V agents)
# For local dev with livekit-server --dev: ws://127.0.0.1:7880, key devkey, secret secret
# LIVEKIT_URL=ws://127.0.0.1:7880
# LIVEKIT_PUBLIC_URL=ws://127.0.0.1:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret
